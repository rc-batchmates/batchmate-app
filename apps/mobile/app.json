{
	"expo": {
		"name": "Batchmate",
		"slug": "batchmate",
		"version": "1.0.0",
		"scheme": "batchmate",
		"platforms": ["ios", "android"],
		"ios": {
			"bundleIdentifier": "app.batchmate.app"
		},
		"android": {
			"package": "app.batchmate.app"
		},
		"plugins": [
			"expo-router",
			[
				"expo-build-properties",
				{
					"ios": {
						"newArchEnabled": true
					},
					"android": {
						"newArchEnabled": true
					}
				}
			],
			"expo-web-browser"
		],
		"experiments": {
			"autolinkingModuleResolution": true
		}
	}
}
