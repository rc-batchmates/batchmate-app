{
	"name": "@batchmate/mobile",
	"version": "0.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start --dev-client",
		"go": "expo start",
		"android": "expo run:android",
		"android:device": "expo run:android --device",
		"ios": "expo run:ios",
		"ios:device": "expo run:ios --device",
		"clear": "expo start --dev-client -c",
		"clean": "rm -rf node_modules ios android && pnpm install",
		"deploy:ios": "eas build -p ios --profile production --auto-submit",
		"deploy:android": "eas build -p android --profile production --auto-submit",
		"deploy:all": "eas build --platform all --profile production --auto-submit",
		"deploy:update": "eas update --channel production",
		"build:ios": "eas build --platform ios --profile production --local",
		"build:android": "eas build --platform android --profile production --local",
		"build:all": "eas build --platform all --profile production --local"
	},
	"dependencies": {
		"@batchmate/api": "workspace:*",
		"@batchmate/api-client": "workspace:*",
		"@batchmate/ui": "workspace:*",
		"@better-auth/expo": "^1.4.19",
		"@orpc/client": "^1.0.0",
		"@orpc/openapi-client": "^1.0.0",
		"@orpc/server": "^1.0.0",
		"@orpc/tanstack-query": "^1.0.0",
		"@tanstack/react-query": "^5.80.7",
		"better-auth": "^1.4.19",
		"expo": "~54.0.7",
		"expo-build-properties": "~1.0.10",
		"expo-constants": "~18.0.3",
		"expo-linking": "~8.0.11",
		"expo-network": "^8.0.8",
		"expo-router": "~6.0.7",
		"expo-secure-store": "^15.0.8",
		"expo-status-bar": "~3.0.9",
		"expo-updates": "~29.0.16",
		"expo-web-browser": "~15.0.10",
		"lucide-react-native": "^0.575.0",
		"nativewind": "5.0.0-preview.3",
		"react": "19.1.0",
		"react-native": "0.81.5",
		"react-native-css": "^3.0.6",
		"react-native-reanimated": "~4.1.7",
		"react-native-safe-area-context": "~5.6.0",
		"react-native-screens": "~4.16.0",
		"react-native-svg": "~15.12.0",
		"react-native-worklets": "^0.5.1"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"@types/react": "~19.1.0",
		"babel-preset-expo": "^54.0.10",
		"postcss": "^8.5.8",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~5.9.3"
	}
}
