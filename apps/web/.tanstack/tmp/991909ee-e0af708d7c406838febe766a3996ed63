import { LoginForm } from "@batchmate/ui"
import { createFileRoute, useNavigate } from "@tanstack/react-router"
import { AuthLayout } from "@/components/auth-layout"
import { signIn } from "@/lib/auth"

export const Route = createFileRoute("/_auth/tsx/login")({
	component: LoginPage,
})

function LoginPage() {
	const navigate = useNavigate()

	return (
		<AuthLayout
			tagline={"The next generation of recurse tooling."}
			taglineSub="Access the hub, manage your schedule & configure your rc thing — all in one place."
		>
			<LoginForm
				onSubmit={async ({ email, password }) => {
					const { error } = await signIn.email({ email, password })
					if (error) {
						if (error.message === "Email not verified") {
							navigate({ to: "/check-email", search: { email } })
							return
						}
						throw new Error(error.message ?? "Sign in failed")
					}
					navigate({ to: "/" })
				}}
				onSignupPress={() => navigate({ to: "/signup" })}
			/>
		</AuthLayout>
	)
}
