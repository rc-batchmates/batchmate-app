{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"types": ["@cloudflare/workers-types"],
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"declaration": true,
		"esModuleInterop": true
	},
	"include": ["src"]
}
